# ==========================================================================
# AIFPL backend configuration. Copy to backend/.env and fill in your values.
# Everything here is OPTIONAL — with nothing set, the deterministic agents,
# the signals endpoint and all pre-existing features still work. Each key
# unlocks the feature next to it.
#
# This file is tracked in git. Never commit your real .env!
# ==========================================================================

# --- Betting odds (The Odds API — https://the-odds-api.com, free 500 req/mo) ---
THE_ODDS_API_KEY=your_api_key_here
BETTING_ODDS_ENABLED=false
BETTING_ODDS_WEIGHT=0.25

# --- Hermes LLM orchestrator (any OpenAI-compatible endpoint) ---------------
# Works with DeepSeek, OpenRouter (Nous Hermes), or any OpenAI-compatible API.
HERMES_ENABLED=true
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_API_KEY=your_llm_api_key_here
LLM_MAX_OUTPUT_TOKENS=2000
LLM_TIMEOUT_SECONDS=120
HERMES_TWO_PASS=false           # second "explain the final squad" LLM pass
HERMES_DAILY_BRIEFING=false     # run a briefing automatically at 03:30 UTC
HERMES_VARIABILITY_POOL=120     # players the variability agent profiles per run

# --- News agent web search (Tavily — https://tavily.com) --------------------
SEARCH_PROVIDER=tavily           # tavily | duckduckgo | (unset = FPL news only)
TAVILY_API_KEY=your_tavily_key_here

# --- Telegram pre-deadline squad notifications ------------------------------
# Bot token from @BotFather; chat id from
# https://api.telegram.org/bot<TOKEN>/getUpdates after messaging the bot.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Database (defaults to local SQLite; use Postgres for persistence) ------
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Misc -------------------------------------------------------------------
# CORS_ORIGINS=https://fplai.nl,http://localhost:3000
# LOG_LEVEL=INFO
# FPL_CACHE_TTL_SECONDS=300
